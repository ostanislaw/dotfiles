[user]
	name = Stanislaw Ostrowski
	email = stanislaw.ostrowski@fluke.com
[core]
	excludesfile = ~/.gitignore
	autocrlf = input
#	pager = diff-highlight | less --tabs=4 -RFX
#[pager]
#	log = diff-highlight | less
#	show = diff-highlight | less
#	diff = diff-highlight | less
[gitreview]
	remote = origin
	branch = develop
	rebase = false
[log]
	abbrevCommit = true
	decorate = auto
[merge]
	tool = kdiff3
[mergetool "kdiff3"]
	trustExitCode = false
	trustExitCode = false
[diff]
	guitool = kdiff3
	guitool = kdiff3
	tool = kdiff3
	wsErrorHighlight = all
[difftool "kdiff3"]
	trustExitCode = false
	trustExitCode = false
[color]
	ui = true
[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = red bold 52
	newNormal = green bold
	newHighlight = green bold 22
[color "diff"]
	meta = 11
	frag = magenta bold
	commit = yellow bold
	old = red bold
	new = green bold
	whitespace = red reverse
#[interactive]
#	diffFilter = diff-highlight
[mergetool]
	keepBackup = false
[rerere]
	enabled = true
[push]
	default = current
	autoSetupRemote = true
#ddd test
#test
#test
[difftool "bc3"]
	trustExitCode = true
[mergetool "bc3"]
	trustExitCode = false
[pull]
	ff = only
